# Personale Artificiale — variabili d'ambiente
# Copia in .env e sostituisci tutti i placeholder prima del deploy.

# Sicurezza/database: genera valori unici, lunghi e non riutilizzati.
POSTGRES_PASSWORD=replace_with_a_very_long_random_postgres_password
JWT_SECRET=replace_with_at_least_64_random_characters
API_RATE_LIMIT=600
AUTH_RATE_LIMIT=20

# URL pubblici
APP_URL=https://app.personaleartificiale.it
WWW_URL=https://www.personaleartificiale.it

# Coesistenza VPS: Personale Artificiale resta su loopback, così un altro sito
# può usare la porta 3000 e un reverse proxy host può usare 80/443.
PA_HTTP_PORT=8081

# Stripe live/test: usa le chiavi corrette per l'ambiente scelto.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_EXECUTIVE_MONTHLY=price_replace_me
STRIPE_PRICE_EXECUTIVE_SETUP=price_replace_me
STRIPE_PRICE_OFFICE_MONTHLY=price_replace_me
STRIPE_PRICE_OFFICE_SETUP=price_replace_me

# OpenAI per RAG e chatbot. Senza questa chiave il bot risponde con fallback locale sulle fonti indicizzate.
OPENAI_API_KEY=sk-proj_replace_me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Qdrant/Evolution
QDRANT_COLLECTION=pa_knowledge
# QDRANT_API_KEY=replace_me_if_using_qdrant_cloud
QDRANT_TIMEOUT_MS=8000
EVOLUTION_API_KEY=replace_with_a_long_random_evolution_key
EVOLUTION_TIMEOUT_MS=10000
