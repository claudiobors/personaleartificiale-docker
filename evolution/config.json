# Evolution API config
{
  "server": {
    "port": 8080,
    "host": "0.0.0.0"
  },
  "CORS": {
    "origin": "*",
    "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "credentials": true
  },
  "auth": {
    "apiKey": "${EVOLUTION_API_KEY}",
    "type": "apikey"
  },
  "whatsapp": {
    "webhook": {
      "enabled": true,
      "url": "https://app.personaleartificiale.it/api/whatsapp/webhook"
    }
  },
  "websocket": {
    "enabled": true
  }
}
